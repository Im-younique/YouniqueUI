{
  "name": "younique-ui",
  "version": "0.1.0",
  "description": "shadcn/ui 기반 React UI 컴포넌트 라이브러리",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build:js": "tsup",
    "build:css": "npx @tailwindcss/cli -i src/styles/globals.css -o dist/styles.css --minify",
    "build:theme": "cp src/styles/theme.css dist/theme.css",
    "build": "pnpm run build:js && pnpm run build:css && pnpm run build:theme",
    "build-storybook": "storybook build",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.18",
    "@tailwindcss/cli": "^4",
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.14",
    "tailwindcss": "^4",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "shadcn",
    "tailwind"
  ],
  "author": "younique",
  "license": "MIT"
}
